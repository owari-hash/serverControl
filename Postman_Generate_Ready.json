    {
      "name": "Core Projects",
      "description": "Төслийн lifecycle (үүсгэх, харах, build, stop, delete) бүх CRUD болон үйлдлүүд.",
      "item": [
        {
          "name": "POST /core/projects/generate",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Амжилттай үүсэв', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "if (json.project && json.project.name) { pm.collectionVariables.set('projectName', json.project.name); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "description": "Project үүсгээд scaffold хийж ажиллуулна.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"projectName\": \"{{projectName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/core/projects/generate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "core",
                "projects",
                "generate"
