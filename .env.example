# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username_here

# Server Configuration
NODE_ENV=production
PORT=4000
PROJECTS_DIR=/home/projects
BASE_PORT=5001
MAX_PROJECTS=50

# Simple Auth (for button api testing)
AUTH_EMAIL=admin@demo.com
AUTH_PASSWORD=123456
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
AUTH_USE_HTTP_ONLY_COOKIE=true
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX_ATTEMPTS=20

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# SSH/Infrastructure execution
SSH_KEY_PATH=/home/ubuntu/.ssh/id_rsa
SSH_CONNECT_TIMEOUT_MS=15000
SSH_COMMAND_TIMEOUT_MS=60000
